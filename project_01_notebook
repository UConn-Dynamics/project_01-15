md"""
### Animation of Pendulum Motion
"""

# ╔═╡ c05f30ff-f972-41f5-b1bc-47df0a788079
begin
    # Animation parameters
    frames = 300
    times_slow = range(sol_slow.t[1], sol_slow.t[end], length=frames)
    times_fast = range(sol_fast.t[1], sol_fast.t[end], length=frames)
    
    # Origin point (rotation axis)
    origin_x = 0.0
    origin_z = 0.0
    
    # Pivot point (where pendulum attaches)
    pivot_x = w1
    pivot_z = h1
end

# ╔═╡ f1dc36d7-eb23-4a89-8444-2e1ee4c6e6cd
begin
    gr()
    
    # Create directory for saving animations if needed
    # (Remove comment markers to save animations)
    # using Printf
    # mkpath("animations")
    
    @gif for i in 1:frames
        # Current time and solution for slow rotation
        t_current = times_slow[i]
        u_current = sol_slow(t_current)
        θ_current = u_current[1]
        
        # Bob position in rotating frame
        bob_x = w1 + L * sin(θ_current)
        bob_z = h1 - L * cos(θ_current)
        
        # Create plot
        p1 = plot([origin_x, pivot_x], [origin_z, pivot_z],
            linewidth=3, color=:black, label="Frame arm")
        plot!(p1, [pivot_x, bob_x], [pivot_z, bob_z],
            linewidth=2, color=:blue, label="Pendulum")
        scatter!(p1, [pivot_x], [pivot_z], 
            markersize=5, color=:red, label="Pivot")
        scatter!(p1, [bob_x], [bob_z],
            markersize=8, color=:green, label="Bob")
        
        # Formatting
        xlabel!("x (m)")
        ylabel!("z (m)")
        title!("Slow Ω = $(Ω_slow) rad/s, t = $(round(t_current, digits=2)) s")
        xlims!(-0.1, 0.3)
        ylims!(0, 0.3)
        aspect_ratio=:equal
        
        # Angle vs time subplot
        p2 = plot(sol_slow.t, sol_slow[1,:],
            xlabel="Time (s)", ylabel="θ (rad)",
            title="Angle vs Time", legend=false)
        scatter!(p2, [t_current], [θ_current])
        
        # Combine plots
        plot(p1, p2, layout=(1,2), size=(900,400))
        
    end every 5  # Take every 5th frame for smoother GIF
end

