# ╔═╡ f17103ea-06bf-11f1-a2b0-79e68ed152eb
md"""# Project_01 - Spinning Pendulum and the Lagrange equations

In this project, a pendulum is attached to a spinning frame. The frame has dimensions, 

$h_1 = 0.2~m$

$w_1 = 0.1~m$

and the pendulum length is $L=0.15~m$ with a $m=0.1~kg$ point mass at the end of the system. The pendulum swings in the $x'-z'-plane$ as it rotates at a constant speed, $\Omega$

![Spinning pendulum with rotating and fixed coordinate systems.](https://raw.githubusercontent.com/cooperrc/me5180-project_01/refs/heads/main/spinning_pendulum.svg)

Your team's goal is to 

- build the equations of motion using Lagrange and least action $L=T-V$
- solve for the motion for a slow rotation speed and a fast rotation speed
- visualize the solution with plots and animations

"""

# ╔═╡ a78fdfa3-31ad-4cf6-b97e-10d0036477d7
begin
    # Given constants
    h1 = 0.2      # m - frame height
    w1 = 0.1      # m - frame width/offset
    L  = 0.15     # m - pendulum length
    m  = 0.1      # kg - mass
    g  = 9.81     # m/s^2 - gravity

    # Choose rotation speeds
    Ω_slow = 2.0   # rad/s - slow rotation
    Ω_fast = 10.0  # rad/s - fast rotation
end

# ╔═╡ 04145a81-9540-4be9-b196-9f25f3a2fde4
md"""
## Lagrange Derivation of Equations of Motion

The Lagrangian is defined as $L = T - V$ where:

**Kinetic Energy**:
$T = \frac{1}{2}mL^2\dot{\theta}^2 + \frac{1}{2}m\Omega^2(w_1 + L\sin\theta)^2$

**Potential Energy**:
$V = mgL(1 - \cos\theta)$
"""

# ╔═╡ baead9fe-fe44-47ea-9df6-aa685f864dc8
begin
    # Symbolic derivation of equations of motion
    @variables t θ(t)
    @parameters m_sym=0.1 L_sym=0.15 g_sym=9.81 Ω_sym=2.0 w_sym=0.1
    
    D = Differential(t)
    
    # Lagrangian: T - V
    T_lagrange = 0.5 * m_sym * (L_sym^2 * (D(θ)^2) + ((w_sym + L_sym*sin(θ))^2 * Ω_sym^2))
    V_lagrange = m_sym * g_sym * L_sym * (1 - cos(θ))
    L_lagrange = T_lagrange - V_lagrange
end

# ╔═╡ 3b6fd224-38f5-4d1c-8f0f-1a2493e47c18
begin
    # Euler-Lagrange equation: d/dt(dL/dθ̇) - dL/dθ = 0
    dL_dθdot = Symbolics.derivative(L_lagrange, D(θ))
    dL_dθ = Symbolics.derivative(L_lagrange, θ)
    
    EL_equation = expand_derivatives(D(dL_dθdot) - dL_dθ)
end

# ╔═╡ eb489e2a-f449-4acf-a3bd-b50afa257930
begin
    # Solve for θ̈
    θddot_expr = Symbolics.solve_for(EL_equation ~ 0, D(D(θ)))
    θddot_simplified = Symbolics.simplify(θddot_expr)
end

# ╔═╡ a8c3fe2c-0ef9-4109-8c1a-b547e33116a7
md"""
The resulting equation of motion is:

$\ddot{\theta} = \Omega^{2}\sin\theta\cos\theta - \frac{g}{L}\sin\theta$
"""

# ╔═╡ 850f64b5-841b-4898-8bab-de2bcc206728
md"""
## Numerical Solution
"""

# ╔═╡ fbe18835-55c7-40a8-808d-022516ab1081
function spinning_pendulum!(du, u, p, t)
    θ, ω = u
    Ω, g, L = p

    du[1] = ω
    du[2] = sin(θ) * (Ω^2 * cos(θ) - g/L)
end

# ╔═╡ b0d52198-3c01-476d-82be-99bd8599ed62
begin
    # Initial conditions
    θ0 = 0.2        # small initial displacement
    ω0 = 0.0

    u0 = [θ0, ω0]
    tspan = (0.0, 20.0)  # longer time to see behavior

    # Solve for slow rotation
    p_slow = (Ω_slow, g, L)
    prob_slow = ODEProblem(spinning_pendulum!, u0, tspan, p_slow)
    sol_slow = solve(prob_slow, Tsit5())
    
    # Solve for fast rotation
    p_fast = (Ω_fast, g, L)
    prob_fast = ODEProblem(spinning_pendulum!, u0, tspan, p_fast)
    sol_fast = solve(prob_fast, Tsit5())
    
    md"Solutions computed for both slow and fast rotation"
end

# ╔═╡ 338d3148-d507-49af-9a88-157c9d2462d1
begin
    plot(sol_slow.t, sol_slow[1,:],
        xlabel="Time (s)",
        ylabel="θ (rad)",
        title="Spinning Pendulum Motion - Comparison",
        label="Slow Ω = $(Ω_slow) rad/s")
    plot!(sol_fast.t, sol_fast[1,:],
        label="Fast Ω = $(Ω_fast) rad/s")
end

# ╔═╡ 6f279ace-14cc-45c0-9cbe-e065928fa3e2
begin
    # Position in rotating frame for slow rotation
    x_slow = L .* sin.(sol_slow[1,:])
    z_slow = h1 .- L .* cos.(sol_slow[1,:])  # z = h1 - L*cos(θ)
    
    # Position in rotating frame for fast rotation
    x_fast = L .* sin.(sol_fast[1,:])
    z_fast = h1 .- L .* cos.(sol_fast[1,:])
    
    plot(x_slow, z_slow,
        xlabel="x (m)",
        ylabel="z (m)",
        aspect_ratio=:equal,
        title="Pendulum Path in Rotating Frame",
        label="Slow Ω",
        linewidth=2)
    plot!(x_fast, z_fast,
        label="Fast Ω",
        linewidth=2)
end

